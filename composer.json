{
    "name": "md-riaz/credledger",
    "description": "CredLedger-Lite — a self-hosted OOP PHP + SQLite app that tracks credential sharing",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "MD Riaz",
            "email": "riaz@example.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-sqlite3": "*",
        "ext-sodium": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "CredLedger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CredLedger\\Tests\\": "tests/"
        }
    }
}
